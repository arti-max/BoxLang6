    box div10[char dividend, char divisor, char* q] (
        if [divisor == 0] (
            ret -1;
        )

        *q: dividend / divisor;
        ret dividend - (*q * divisor); // остаток
    )

    box reverse8[char* str, char len] (
        char* start: str;
        char* end: str+len-1;
        char tmp;

        while [start < end] (
            tmp: *start;
            *start: *end;
            *end: tmp;
            start:start+1;
            end:end-1;
        )
    )

    box itoa8[char num8, char* buf] (
        /*char* ptr: buf;
