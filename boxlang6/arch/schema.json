{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BoxLang Arch Config",
  "type": "object",
  "required": [
    "name", "bits", "endian", "registers",
    "calling_convention", "var_storage",
    "ops", "instructions",
    "prologue", "epilogue", "output"
  ],
  "additionalProperties": true,
  "properties": {

    "name":   { "type": "string" },
    "bits":   { "type": "integer", "enum": [2, 4, 8, 16, 32] },
    "endian": { "type": "string",  "enum": ["little", "big"]  },

    "registers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "bits"],
        "additionalProperties": false,
        "properties": {
          "id":   { "type": "integer", "minimum": 0 },
          "bits": { "type": "integer", "enum": [2, 4, 8, 16, 32] }
        }
      }
    },

    "calling_convention": {
    "type": "object",
    "required": ["arg_passing", "return", "stack_align", "preserved"],
    "properties": {
        "arg_passing":      { "type": "string", "enum": ["registers", "stack"] },
        "args":             { "type": "array", "items": { "type": "string" } },
        "return":           { "type": "string" },
        "stack_align":      { "type": "integer", "minimum": 0 },
        "preserved":        { "type": "array",   "items": { "type": "string" } },
        "arg_base_offset":  { "type": "integer", "minimum": 0 }
      }
    },

    "var_storage": { "type": "string" },
    "var_alloc":   { "$ref": "#/definitions/step" },
    "var_load":    { "$ref": "#/definitions/step" },
    "var_store":   { "$ref": "#/definitions/step" },
    "var_regs":    { "type": "array", "items": { "type": "string" } },

    "ops": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["steps"],
        "properties": {
          "desc":  { "type": "string" },
          "steps": { "type": "array", "items": { "$ref": "#/definitions/step" } }
        }
      }
    },

    "instructions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["variants"],
        "properties": {
          "desc":     { "type": "string" },
          "variants": {
            "type": "object",
            "additionalProperties": { "$ref": "#/definitions/variant" }
          }
        }
      }
    },

    "syscalls": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["steps"],
        "properties": {
          "desc":  { "type": "string" },
          "steps": { "type": "array", "items": { "$ref": "#/definitions/step" } }
        }
      }
    },

    "prologue": { "type": "array", "items": { "$ref": "#/definitions/step" } },
    "epilogue": { "type": "array", "items": { "$ref": "#/definitions/step" } },

    "output": {
      "type": "object",
      "required": ["format", "origin", "entry"],
      "properties": {
        "format": { "type": "string", "enum": ["raw", "com", "elf", "bin"] },
        "origin": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" },
        "entry":  { "type": "string" }
      }
    }
  },

  "definitions": {

    "step": {
      "type": "object",
      "required": ["insn", "args"],
      "properties": {
        "insn":    { "type": "string" },
        "variant": { "type": "string" },
        "args":    { "type": "array", "items": { "type": "string" } }
      }
    },

    "variant": {
      "type": "object",
      "required": ["size_bits", "fields"],
      "properties": {
        "desc":      { "type": "string" },
        "size_bits": { "type": "integer", "enum": [4, 8, 16, 24, 32, 48, 64] },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/field" }
        }
      }
    },

    "field": {
      "type": "object",
      "required": ["bits", "source"],
      "properties": {
        "bits": {
          "type": "string",
          "pattern": "^[0-9]+:[0-9]+$"
        },
        "source": {
          "type": "string",
          "pattern": "^(const:(0x[0-9a-fA-F]+|[0-9]+)|arg:[0-9]+:(imm|imm\\.lo8|imm\\.hi8|imm\\.lo4|imm\\.hi4|reg\\.id|reg\\.bits|var\\.offset|var\\.addr)|label:(rel8|rel16|rel16\\.lo8|rel16\\.hi8|abs4|abs8|abs16|abs16\\.lo8|abs16\\.hi8))$"
        }
      }
    }

  }
}
